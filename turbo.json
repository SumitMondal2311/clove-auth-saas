{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"]
        },
        "api#build": {
            "dependsOn": ["^build"],
            "env": [
                "REFRESH_TOKEN_EXPIRY",
                "DB_MAX_RETRIES",
                "NODE_ENV",
                "PORT",
                "API_ORIGIN",
                "WEB_ORIGIN",
                "DB_URL",
                "JWT_KID",
                "JWT_ISS",
                "ACCESS_TOKEN_EXPIRY",
                "REDIS_URL",
                "EMAIL_VERIFICATION_TOKEN_EXPIRY_MS"
            ],
            "outputs": ["dist/**"]
        },
        "dashboard#build": {
            "dependsOn": ["^build"],
            "env": ["NODE_ENV"],
            "outputs": [".next/**", "!.next/cache/**"]
        },
        "db:deploy": {
            "cache": false
        },
        "db:migrate": {
            "cache": false,
            "persistent": true
        },
        "db:generate": {
            "cache": false
        },
        "db:push": {
            "cache": false
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "clean": {
            "dependsOn": ["^clean"],
            "cache": false
        },
        "dev": {
            "dependsOn": ["^dev"],
            "cache": false
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "start": {
            "dependsOn": ["^start"],
            "cache": false
        },
        "test:integration": {
            "dependsOn": ["^test:integration"],
            "env": [
                "REFRESH_TOKEN_EXPIRY",
                "DB_MAX_RETRIES",
                "NODE_ENV",
                "PORT",
                "API_ORIGIN",
                "WEB_ORIGIN",
                "DB_URL",
                "JWT_KID",
                "JWT_ISS",
                "ACCESS_TOKEN_EXPIRY",
                "REDIS_URL",
                "EMAIL_VERIFICATION_TOKEN_EXPIRY_MS"
            ],
            "cache": false
        }
    }
}
